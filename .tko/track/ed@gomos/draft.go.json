            "content": "package main\n\nimport \"fmt\"\n\nfunc main() {\n\tvar Q int\n\tvar D string\n\tfmt.Scan(&Q, &D)\n\t//ler posi\u00e7\u00f5es x e y\n\tvar x [100]int\n\tvar y [100]int\n\tfor i := 0; i < Q; i++ {\n\t\tfmt.Scan(&x[i], &y[i])\n\t}\n\n\t//cada gomo subsequente \u00e9 a posi\u00e7\u00e3o anterior + um passo na dire\u00e7\u00e3o D\n\tfor i := Q - 1; i > 0; i-- {\n\t\tx[i] = x[i-1]\n\t\ty[i] = y[i-1]\n\t}\n\t//a depender da dire\u00e7\u00e3o D, calcular a nova posi\u00e7\u00e3o da cabe\u00e7a\n\n\tswitch D {\n\tcase \"L\":\n\t\tx[0]--\n\tcase \"R\":\n\t\tx[0]++\n\t\t//eixo y aumenta para baixo\n\tcase \"U\":\n\t\ty[0]--\n\tcase \"D\":\n\t\ty[0]++\n\t}\n\n\tfor i := 0; i < Q; i++ {\n\t\tfmt.Println(x[i], y[i])\n\t}\n\n}\n",
